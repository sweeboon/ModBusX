@startuml
' ========== PACKAGE STRUCTURE ==========
package "modbusx.core" {
    class ModbusDevice {
        - address: str
        - port: int
        - is_open: bool
        - slaves: List<ModbusSlave>
        + add_slave()
        + remove_slave()
    }

    class ModbusSlave {
        - slave_id: int
        - register_map: RegisterMap
        - groups: List<RegisterGroupMeta>
        + add_register_group()
        + remove_register_group()
    }
    class RegisterMap {
        - hr: Dict<int, RegisterEntry>
        - ir: Dict<int, RegisterEntry>
        - co: Dict<int, RegisterEntry>
        - di: Dict<int, RegisterEntry>
        + add_block()
        + as_pymodbus_array()
        + all_entries()
        + find_entry_by_addr()
    }
    class RegisterEntry {
        - addr: int
        - reg_type: str
        - value: int
        - alias: str
        - comment: str
        - units: str
    }
    ' Stand-in for group nodes in tree (not the register data itself)
    class RegisterGroupMeta {
        - register_id: int
        - reg_type: str
        - start_addr: int
        - size: int
        - parent_slave_map: RegisterMap
    }
}

package "modbusx.slave_server" {
    class MultiUnitModbusServerThread {
        - port: int
        - unit_definitions: Dict<int, Dict<str, Tuple<int, List<int>>>>
        + start()
        + stop()
        + status_signal
        + error_signal
    }
}

package "modbusx.ui" {
    class MainWindow <<QMainWindow>> {
        - treeView
        - tableView
        - tree_model: QStandardItemModel
        - reg_table_model: QStandardItemModel
        + show_connect_dialog()
        + add_connection()
        + open_selected_connection()
        + ...
    }
    class ConnectDialog <<QDialog>> {
        - settings: Dict
        + on_ok()
    }
}

' ========== RELATIONSHIPS ==========
ModbusDevice "1" -- "0..*" ModbusSlave : slaves
ModbusSlave "1" -- "1" RegisterMap : "holds"
ModbusSlave "1" -- "0..*" RegisterGroupMeta : "tree groups"
RegisterMap "1" -- "0..*" RegisterEntry
RegisterGroupMeta "1" ..> RegisterMap : parent

' UI->Model and Backend
MainWindow ..> ModbusDevice : manages
MainWindow ..> MultiUnitModbusServerThread : starts/stops
MainWindow ..> ConnectDialog : uses

' ServerThread expects:
'   unit_definitions: Dict<slave_id, Dict<regtype, (start_addr, array)>>
MultiUnitModbusServerThread ..> RegisterMap : uses as value provider

@enduml