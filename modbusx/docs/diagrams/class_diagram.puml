' ============== SERVER PACKAGE ==============
package "server" #SkyBlue {
  
  class AsyncModbusServer {
    - config: ServerConfig
    - live_slaves: Dict[int, Dict]
    - server_task: Optional[asyncio.Task]
    - function_registry: FunctionHandlerRegistry
    + start()
    + stop()
    + refresh_server_context()
    + is_running(): bool
    + _parse_request_common(data, is_tcp): ModbusRequest
    + _get_slave_context(unit_id): slave_context
    + _build_final_response(response, is_tcp): bytes
    ..Uses function handlers to eliminate duplicate code..
  }
  
  class FunctionHandlerRegistry {
    - _handlers: Dict[int, BaseFunctionHandler]
    - logger: Logger
    + get_handler(function_code): BaseFunctionHandler
    + handle_request(request, slave_context): ModbusResponse
    + get_supported_functions(): List[int]
    + is_supported(function_code): bool
    ..Centralized registry eliminates if-elif chains..
  }
  
  class BaseFunctionHandler {
    <<abstract>>
    - logger: Logger
    + get_register_type_code(): int
    + get_function_name(): str
    + build_response_data(values, quantity): bytes
    + handle_request(request, slave_context): ModbusResponse
    ..Base class eliminates duplicate logic across functions..
  }
  
  class ReadCoilsHandler {
    + get_register_type_code(): int = 1
    + get_function_name(): str = "Read Coils"
    + build_response_data(values, quantity): bytes
    ..Bit-packed response for coils (0x01)..
  }
  
  class ReadDiscreteInputsHandler {
    + get_register_type_code(): int = 2
    + get_function_name(): str = "Read Discrete Inputs"  
    + build_response_data(values, quantity): bytes
    ..Bit-packed response for discrete inputs (0x02)..
  }
  
  class ReadHoldingRegistersHandler {
    + get_register_type_code(): int = 3
    + get_function_name(): str = "Read Holding Registers"
    + build_response_data(values, quantity): bytes
    ..Word-packed response for holding registers (0x03)..
  }
  
  class ReadInputRegistersHandler {
    + get_register_type_code(): int = 4
    + get_function_name(): str = "Read Input Registers"
    + build_response_data(values, quantity): bytes
    ..Word-packed response for input registers (0x04)..
  }
  
  class ModbusRequest {
    + unit_id: int
    + function_code: int
    + start_addr: int
    + quantity: int
    + raw_data: bytes
    ..Common request structure for all protocols..
  }
  
  class ModbusResponse {
    + unit_id: int
    + function_code: int
    + data: bytes
    + needs_crc: bool
    ..Common response structure for all protocols..
  }

  class ServerConfig {
